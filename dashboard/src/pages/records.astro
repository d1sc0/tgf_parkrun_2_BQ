---
import Layout from '../layouts/Layout.astro';
import Records from '../components/Records.astro';

// Check for user state from middleware (src/middleware.ts)
const user = Astro.locals.user;

// Server-side protection: Redirect to login if not authenticated
if (!user) {
  return Astro.redirect('/login');
}
---

<Layout
  title="Records"
  description="Breakdown of fastest time per age category"
>
  <Records />
</Layout>
